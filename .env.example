# Application
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/infinitepay_middleware

# InfinitePay
INFINITEPAY_API_URL=https://api.infinitepay.io/v2
INFINITEPAY_API_KEY=your-infinitepay-api-key
INFINITEPAY_CLIENT_ID=your-client-id
INFINITEPAY_CLIENT_SECRET=your-client-secret
INFINITEPAY_WEBHOOK_SECRET=your-webhook-secret

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
